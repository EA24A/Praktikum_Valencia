# Database (PostgreSQL 15+)
DATABASE_URL="postgresql://user:password@localhost:5432/casapos?schema=public"

# Auth.js / NextAuth v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
APP_NAME="Casa POS"
APP_LOCALE="es"

# Shared restaurant PC login — excluded from time-tracking staff list
TERMINAL_USER_EMAIL="pos@casapos.local"

# Legacy NextAuth env (optional fallback)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Resend (optional — for email receipts; enable in Admin → Settings)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Casa Fenicia <onboarding@resend.dev>"

# Website catalog sync (Casa Fenicia pulls menu/prices from POS)
CATALOG_SYNC_SECRET="shared-secret-with-website"
# Optional: push website to re-sync after product changes in POS admin
WEB_CATALOG_SYNC_URL="https://www.casafenicia.com/api/webhooks/pos-catalog"
WEB_CATALOG_SYNC_SECRET="shared-secret-with-website"
