generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  EMPLOYEE
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  ONLINE
}

enum PaymentMethod {
  CASH
  CARD
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  COMBO
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  password      String
  role          Role        @default(EMPLOYEE)
  isActive      Boolean     @default(true)
  isOwner       Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  timeEntries   TimeEntry[]
  ordersCreated Order[]     @relation("CreatedBy")
  ordersPaid    Order[]     @relation("PaidBy")
  refundsIssued Refund[]
  luggageStorage LuggageStorage[]

  @@index([email])
}

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  note      String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([clockIn])
}

model LuggageStorage {
  id            String    @id @default(cuid())
  guestName     String
  phoneNumber   String
  guestEmail    String?
  startedAt     DateTime
  durationHours Int
  bagCount      Int       @default(1)
  price         Decimal   @default(0) @db.Decimal(10, 2)
  isPaid        Boolean   @default(false)
  pickedUpAt    DateTime?
  notes         String?
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([startedAt])
  @@index([pickedUpAt])
  @@index([createdById])
}

model Category {
  id        String    @id @default(cuid())
  nameEs    String
  nameEn    String
  nameDe    String    @default("")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id         String      @id @default(cuid())
  categoryId String
  category   Category    @relation(fields: [categoryId], references: [id])
  nameEs     String
  nameEn     String
  nameDe     String      @default("")
  price      Decimal     @db.Decimal(10, 2)
  taxRate    Decimal     @default(21.00) @db.Decimal(5, 2)
  isActive   Boolean     @default(true)
  posOnly    Boolean     @default(false)
  sortOrder  Int         @default(0)
  comboComponentIds String[] @default([])
  comboComponentGroups Json?
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

model Table {
  id        String   @id @default(cuid())
  number    String
  x         Float    @default(0)
  y         Float    @default(0)
  width     Float    @default(10)
  height    Float    @default(10)
  color     String   @default("#3b82f6")
  shape     String   @default("rectangle")
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Discount {
  id                  String       @id @default(cuid())
  nameEs              String
  nameEn              String
  type                DiscountType @default(PERCENTAGE)
  value               Decimal      @db.Decimal(10, 2)
  isCombo             Boolean      @default(false)
  comboProducts       String[]
  requiresCashPayment Boolean      @default(false)
  isActive            Boolean      @default(true)
  orders              Order[]      @relation("OrderDiscounts")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Order {
  id              String         @id @default(cuid())
  receiptNumber   String?
  tableId         String?
  table           Table?         @relation(fields: [tableId], references: [id])
  status          OrderStatus    @default(OPEN)
  type            OrderType      @default(DINE_IN)
  subtotal        Decimal        @db.Decimal(10, 2)
  taxTotal        Decimal        @db.Decimal(10, 2)
  discountTotal   Decimal        @default(0) @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  amountTendered  Decimal?       @db.Decimal(10, 2)
  changeGiven     Decimal?       @db.Decimal(10, 2)
  isSplitBill       Boolean        @default(false)
  splitCount        Int?
  paidSplitIndices  Int[]          @default([])
  splitPayments     Json?
  cardReference   String?
  items           OrderItem[]
  discounts       Discount[]     @relation("OrderDiscounts")
  refunds         Refund[]
  createdById     String
  createdBy       User           @relation("CreatedBy", fields: [createdById], references: [id])
  paidById        String?
  paidBy          User?          @relation("PaidBy", fields: [paidById], references: [id])
  kitchenCompletedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  paidAt          DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([tableId])
  @@index([createdById])
  @@index([paidAt])
  @@index([receiptNumber])
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  quantity   Int       @default(1)
  unitPrice  Decimal   @db.Decimal(10, 2)
  taxRate    Decimal   @db.Decimal(5, 2)
  subtotal   Decimal   @db.Decimal(10, 2)
  taxAmount  Decimal   @db.Decimal(10, 2)
  total      Decimal   @db.Decimal(10, 2)
  splitIndex Int?
  splitAllocations Json?
  isVoided   Boolean   @default(false)
  voidedAt   DateTime?
  voidedById String?
  voidReason String?
  customName   String?
  customReason String?
  comboSourceProductIds String[] @default([])
  createdAt  DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
}

model Refund {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  amount     Decimal  @db.Decimal(10, 2)
  reason     String
  issuedById String
  issuedBy   User     @relation(fields: [issuedById], references: [id])
  createdAt  DateTime @default(now())
}

model Settings {
  id                    String   @id @default("default")
  businessName          String   @default("Casa POS")
  businessAddress       String   @default("")
  businessPhone         String   @default("")
  taxId                 String   @default("")
  defaultTaxRate        Decimal  @default(21.00) @db.Decimal(5, 2)
  currencySymbol        String   @default("€")
  receiptHeaderEs       String   @default("")
  receiptHeaderEn       String   @default("")
  receiptFooterEs       String   @default("¡Gracias!")
  receiptFooterEn       String   @default("Thank you!")
  kitchenPrintingEnabled Boolean @default(false)
  receiptEmailEnabled    Boolean @default(false)
  receiptFromEmail       String  @default("")
  mapWidth              Int      @default(100)
  mapHeight             Int      @default(100)
  cashRegisterBalance   Decimal  @default(0) @db.Decimal(10, 2)
  registerOpeningFloat  Decimal  @default(50) @db.Decimal(10, 2)
  registerCacheVersion Int     @default(0)
  lastCardReference    String?
  updatedAt             DateTime @updatedAt
}
