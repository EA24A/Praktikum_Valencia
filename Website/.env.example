# Database (your VPS PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/casafenicia"

# NextAuth (Auth.js v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://www.casafenicia.com"
AUTH_TRUST_HOST="true"
# Legacy alias — keep in sync with AUTH_URL if set
NEXTAUTH_URL="https://www.casafenicia.com"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@casafenicia.com"
ADMIN_EMAIL="admin@casafenicia.com"
RESERVATION_ADMIN_EMAIL="ali@casafenicia.com"

# App – canonical URL used by sitemap, structured data, hreflang and OpenGraph.
# IMPORTANT: must match the live host exactly (no trailing slash).
NEXT_PUBLIC_SITE_URL="https://www.casafenicia.com"
NEXT_PUBLIC_APP_URL="https://www.casafenicia.com"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Vercel Blob (Storage → Blob → your store → .env.local in Vercel dashboard)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── Site ownership verification (paste the raw code only, no <meta> markup) ───
# Get from https://search.google.com/search-console (Property → Settings → Ownership)
GOOGLE_SITE_VERIFICATION=""
# Get from https://www.bing.com/webmasters → Add Site → HTML meta tag method
BING_SITE_VERIFICATION=""
# Get from https://webmaster.yandex.com (Site → Settings → Verification)
YANDEX_VERIFICATION=""
# Get from https://www.pinterest.com/settings/claim
PINTEREST_SITE_VERIFICATION=""
# Get from https://business.facebook.com/settings → Brand Safety → Domains
FACEBOOK_DOMAIN_VERIFICATION=""
# Get from Yahoo Site Explorer (legacy, optional)
YAHOO_SITE_VERIFICATION=""

# ─── Casa POS catalog sync (menu/prices source of truth) ───
# Same secret as CASAPOS CATALOG_SYNC_SECRET
POS_CATALOG_SYNC_URL="https://your-pos-domain.com/api/catalog/sync"
POS_CATALOG_SYNC_SECRET="shared-secret-with-website"
